local STREAK_POSITIONS = {
    Vector3.new(50000,  155000,  0),
    Vector3.new(-50000, 155000,  50000),
    Vector3.new(0,      155000, -50000),
}
local PLATFORM_SIZE = Vector3.new(2, 1, 2)

local function createStreakPlatforms()
    if streakPlatforms then
        for _, p in pairs(streakPlatforms) do if p and p.Parent then p:Destroy() end end
    end
    streakPlatforms = {}
    for i, pos in ipairs(STREAK_POSITIONS) do
        local p = Instance.new("Part")
        p.Name = "XKZNN_StreakPlatform_" .. i
        p.Size = PLATFORM_SIZE
        p.CFrame = CFrame.new(pos - Vector3.new(0, 5, 0))
        p.Anchored = true; p.Transparency = 0.4
        p.BrickColor = BrickColor.new("Bright blue")
        p.Material = Enum.Material.ForceField
        p.CanTouch = false; p.CanQuery = false
        p.Parent = workspace
        streakPlatforms[i] = p
    end
end

local function removeStreakPlatforms()
    if streakPlatforms then
        for _, p in pairs(streakPlatforms) do if p and p.Parent then p:Destroy() end end
        streakPlatforms = nil
    end
end

local function runStreakFarm()
    createStreakPlatforms()
    local lockConn = RunService.Heartbeat:Connect(function()
        if not STREAK_FARM_ENABLED then return end
        local char = player.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        if hrp and hum and hum.Health > 0 then
            pcall(function()
                hrp.CFrame = CFrame.new(STREAK_POSITIONS[streakCurrentIndex])
                hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
            end)
            for _, p in pairs(char:GetDescendants()) do
                if p:IsA("BasePart") then
                    p.CanTouch = false; p.CanQuery = false
                    if p.Name ~= "HumanoidRootPart" then p.CanCollide = false end
                end
            end
        end
    end)
    while STREAK_FARM_ENABLED and RUNNING do
        local elapsed = 0
        while STREAK_FARM_ENABLED and elapsed < STREAK_INTERVAL do
            elapsed = elapsed + task.wait(0.1)
        end
        if not STREAK_FARM_ENABLED then break end
        streakCurrentIndex = (streakCurrentIndex % #STREAK_POSITIONS) + 1
    end
    lockConn:Disconnect()
    removeStreakPlatforms()
    local char = player.Character
    if char then
        for _, p in pairs(char:GetDescendants()) do
            if p:IsA("BasePart") then p.CanTouch = true; p.CanQuery = true; p.CanCollide = true end
        end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if hrp then pcall(function() hrp.CFrame = CFrame.new(0, 10, 0) end) end
    end
end

