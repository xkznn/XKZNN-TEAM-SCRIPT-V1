            mapModel.Parent = workspace
            mapModel:ScaleTo(mapModel:GetScale() * MAP_SCALE)

            for _, part in pairs(mapModel:GetDescendants()) do
                if part:IsA("BasePart") then
                    if part.Transparency > 1 and part.CanCollide then
                        part.CanCollide = false
                    end
                    if part.CanCollide then
                        part.CustomPhysicalProperties = PhysicalProperties.new(0.7, 0, 1, 0.5, 1)
                    end
                end
            end

            local targetPos = Vector3.new(rootPart.Position.X, MAP_HEIGHT, rootPart.Position.Z)
            mapModel:MoveTo(targetPos)

            task.wait(0.6)

            local mapCenter = mapModel:GetModelCFrame()
            rootPart.CFrame = mapCenter + Vector3.new(0, 20, 0)

            game:GetService("StarterGui"):SetCore("SendNotification", {
                Title = "Map Loader", Text = "Map loaded! Scale: " .. MAP_SCALE .. "x", Duration = 4
            })
        end)

        if not success then
            game:GetService("StarterGui"):SetCore("SendNotification", {
                Title = "Map Loader Error", Text = "Failed to load map. Check the Asset ID.", Duration = 5
            })
            warn(err)
        end
    end,
})

