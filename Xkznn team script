-- ===== DEMON LAG (declared early so keybind callback can use it) =====
local function fireDemonLag()
    local char = player.Character
    local r = char and char:FindFirstChild("HumanoidRootPart")
    if r then
        pcall(function()
            local look = camera.CFrame.LookVector * Vector3.new(1, 0, 1)
            local horiz = look.Magnitude > 0 and look.Unit * DEMON_LAG_SPEED or Vector3.new(0,0,0)
            r.AssemblyLinearVelocity = Vector3.new(horiz.X, DEMON_LAG_HEIGHT, horiz.Z)
        end)
    end
    if DEMON_LAG_MS > 0 then
        local s = os.clock()
        while os.clock() - s < (DEMON_LAG_MS / 1000) do end
    end
end

