-- RENDER LOOP
-- ===================================================
RunService.RenderStepped:Connect(function()
    local char = player.Character
    local r = char and char:FindFirstChild("HumanoidRootPart")
    if not r then return end
    local hum = char:FindFirstChildOfClass("Humanoid")

    if DOWNED_DASH_ENABLED and hum and hum.Health <= 0
        and UserInputService:IsKeyDown(Enum.KeyCode.LeftControl)
        and not FLY_ENABLED then
        hum.WalkSpeed = 0
        local ld = camera.CFrame.LookVector * Vector3.new(1, 0, 1)
        if ld.Magnitude > 0 then
            pcall(function() r.Velocity = (ld.Unit * DOWNED_DASH_SPEED) + Vector3.new(0, -35, 0) end)
        end
    elseif hum then
        hum.JumpPower = JUMP_POWER_VAL or 50
    end

    local pt = hum and hum:GetPlayingAnimationTracks() or {}
    local ie = #pt > 0
    if EMOTE_SPIN_ENABLED and ie then
        r.CFrame = r.CFrame * CFrame.Angles(0, math.rad(50), 0)
    end
    if AUTO_360_EMOTE_ENABLED and ie then
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then
            r.CFrame = r.CFrame * CFrame.Angles(0, math.rad(120), 0)
        elseif UserInputService:IsKeyDown(Enum.KeyCode.D) then
            r.CFrame = r.CFrame * CFrame.Angles(0, math.rad(-120), 0)
        end
    end

    if FLY_ENABLED then
        local d = Vector3.new(0, 0, 0)
        local cam = camera.CFrame
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then d += cam.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then d -= cam.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then d -= cam.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then d += cam.RightVector end
        local vy = 0
        if UserInputService:IsKeyDown(Enum.KeyCode.Space)        then vy =  FLY_SPEED_VAL
        elseif UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then vy = -FLY_SPEED_VAL end
        pcall(function() r.Velocity = Vector3.new(d.X * FLY_SPEED_VAL, vy, d.Z * FLY_SPEED_VAL) end)

    elseif REALISTIC_BHOP_ENABLED and hum
        and hum.FloorMaterial ~= Enum.Material.Air
        and r.AssemblyLinearVelocity.Magnitude > 1 then
        pcall(function()
            r.AssemblyLinearVelocity = Vector3.new(r.AssemblyLinearVelocity.X, 20, r.AssemblyLinearVelocity.Z)
        end)
        task.spawn(function()
            pcall(function()
                if VirtualInputManager then
                    VirtualInputManager:SendKeyEvent(true,  Enum.KeyCode.LeftControl, false, game)
                    task.wait(0.05)
                    VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.LeftControl, false, game)
                end
            end)
        end)

    elseif JUMP_ENABLED and hum
        and hum.FloorMaterial ~= Enum.Material.Air
        and r.AssemblyLinearVelocity.Magnitude > 1 then
        pcall(function()
            r.AssemblyLinearVelocity = Vector3.new(r.AssemblyLinearVelocity.X, 20, r.AssemblyLinearVelocity.Z)
        end)
    end

    if MOTION_BLUR_ENABLED then
        pcall(function() MotionBlur.Size = math.clamp(r.Velocity.Magnitude / 2, 0, MOTION_BLUR_STRENGTH) end)
    end

    if AUTO_BOUNCE_ENABLED and hum and hum.FloorMaterial ~= Enum.Material.Air then
        pcall(function()
            r.AssemblyLinearVelocity = Vector3.new(
                r.AssemblyLinearVelocity.X, BOUNCE_POWER, r.AssemblyLinearVelocity.Z
            )
        end)
    end
end)

