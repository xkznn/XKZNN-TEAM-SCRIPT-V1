VisualTab:CreateSection("Headless")

local headlessEnabled = false
local headlessLoopConn = nil
local headlessDescConn = nil

local function enforceHeadless()
    local char = player.Character; if not char then return end
    local head = char:FindFirstChild("Head"); if not head then return end
    pcall(function() head.Transparency = 1; head.LocalTransparencyModifier = 1 end)
    for _, obj in pairs(head:GetChildren()) do
        pcall(function()
            if obj:IsA("Decal") then obj.Transparency = 1
            elseif obj:IsA("SpecialMesh") then obj.Scale = Vector3.new(0,0,0) end
        end)
    end
end

local function restoreHead()
    local char = player.Character; if not char then return end
    local head = char:FindFirstChild("Head"); if not head then return end
    pcall(function() head.Transparency = 0; head.LocalTransparencyModifier = 0 end)
    for _, obj in pairs(head:GetChildren()) do
        pcall(function()
            if obj:IsA("Decal") then obj.Transparency = 0
            elseif obj:IsA("SpecialMesh") then obj.Scale = Vector3.new(1,1,1) end
        end)
    end
end

local function startHeadless()
    if headlessLoopConn then headlessLoopConn:Disconnect() end
    if headlessDescConn then headlessDescConn:Disconnect() end
    headlessLoopConn = RunService.Heartbeat:Connect(function()
        if headlessEnabled then enforceHeadless() end
    end)
    local char = player.Character
    if char then
        headlessDescConn = char.DescendantAdded:Connect(function()
            task.wait()
            if headlessEnabled then enforceHeadless() end
        end)
    end
    enforceHeadless()
end

local function stopHeadless()
    if headlessLoopConn then headlessLoopConn:Disconnect(); headlessLoopConn = nil end
    if headlessDescConn then headlessDescConn:Disconnect(); headlessDescConn = nil end
    restoreHead()
end

VisualTab:CreateToggle({
    Name = "Headless",
    CurrentValue = false,
    Flag = "Headless",
    Callback = function(val)
        headlessEnabled = val
        if val then startHeadless() else stopHeadless() end
    end,
})

player.CharacterAdded:Connect(function()
    task.wait(1.5)
    if headlessEnabled then startHeadless() end
end)

VisualTab:CreateSection("Korblox Giver")

local korbloxEnabled = false
local korbloxAccessory = nil

local function applyKorblox()
    local char = player.Character; if not char then return end
    if korbloxAccessory and korbloxAccessory.Parent then korbloxAccessory:Destroy(); korbloxAccessory = nil end
    local ok = pcall(function()
        local acc = game:GetObjects("rbxassetid://139607718")[1]
        if acc then acc.Parent = char; korbloxAccessory = acc end
    end)
    if not ok or not korbloxAccessory then
        pcall(function()
            local IS = game:GetService("InsertService")
            local model = IS:LoadAsset(139607718)
            local acc = model:FindFirstChildOfClass("Accessory") or model:FindFirstChildOfClass("Hat")
            if acc then acc.Parent = char; korbloxAccessory = acc; model:Destroy()
            else model:Destroy() end
        end)
    end
end

local function removeKorblox()
    if korbloxAccessory and korbloxAccessory.Parent then korbloxAccessory:Destroy() end
    korbloxAccessory = nil
    local char = player.Character
    if char then
        for _, obj in pairs(char:GetChildren()) do
            if (obj:IsA("Accessory") or obj:IsA("Hat")) and obj.Name:lower():find("korblox") then obj:Destroy() end
        end
    end
end

